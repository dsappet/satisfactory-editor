# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Raw game Docs.json files (large, owned by Coffee Stain). The parsed,
# slimmed-down JSON in src/data/ is checked in instead.
/data/*.json

# Sample .sav files used for local smoke tests — personal saves shouldn't
# land in the repo. Scripts under scripts/test-*-roundtrip.ts expect one at
# test/<name>.sav but the file itself stays out of version control.
/test/*.sav

# Stale binary Bun lockfile — bun.lock (text) is the source of truth.
bun.lockb

# Local Claude Code state (per-developer permissions, transcripts, settings).
# Untracked today but explicitly ignored so a `git add -A` can't leak it.
/.claude/
